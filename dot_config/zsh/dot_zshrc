function yy() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXX")"
  command yazi "$@" --cwd-file="$tmp"
  if cwd="$(<"$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

smart_cache_eval() {
  local name=$1
  local cmd=$2
  local binary=$(whence -p $name)
  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zinit"
  local cache_file="${cache_dir}/eval_${name}.zsh"

  # 确保缓存目录存在
  [[ -d "$cache_dir" ]] || mkdir -p "$cache_dir"

  # 如果缓存文件不存在，或者二进制文件比缓存文件新，则重建
  if [[ ! -f "$cache_file" || ! -f "{$cache_file}.zwc" || ("$binary" -nt "$cache_file" ) ]]; then
      eval "$cmd" >| "$cache_file"
      zcompile "$cache_file"
  fi
  source "$cache_file"
}

smart_cache_eval "mise"     "mise activate zsh"
smart_cache_eval "direnv"   "direnv hook zsh"
smart_cache_eval "starship" "starship init zsh"
smart_cache_eval "zoxide"   "zoxide init zsh"
